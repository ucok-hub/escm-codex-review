# Template konfigurasi Codex Review Bot.
# SALIN file ini menjadi ".env" lalu isi nilainya. JANGAN commit file .env asli.
#   Windows PowerShell:  Copy-Item .codex-review/.env.example .codex-review/.env
#   Git Bash:            cp .codex-review/.env.example .codex-review/.env

# WAJIB — kunci OpenAI. Mesin tidak akan jalan tanpa ini.
OPENAI_API_KEY=sk-isi-kunci-anda-di-sini

# Model LLM (default gpt-4o-mini sesuai skripsi).
OPENAI_MODEL=gpt-4o-mini

# Port server backend GUI.
PORT=8787

# (Opsional) Estimasi biaya — harga per 1 juta token. Isi sesuai tarif OpenAI
# agar laporan menampilkan estimasi biaya. Kosongkan jika tidak perlu.
CODEX_PRICE_PROMPT_PER_1M=0.15
CODEX_PRICE_COMPLETION_PER_1M=0.60
CODEX_PRICE_CURRENCY=USD

# (Opsional) Batas token output per panggilan & paralelisme.
MAX_OUTPUT_TOKENS=2000
CODEX_CONCURRENCY=4

# --- Hosting publik (mis. Render) --------------------------------------------
# Passcode "by invitation" untuk endpoint scan live. KOSONG = tanpa gerbang
# (mode lokal). Di hosting publik WAJIB diisi agar token OpenAI-mu tak
# disalahgunakan pengunjung.
ACCESS_CODE=
# Batas jumlah scan live per jam (lindungi anggaran token).
MAX_LIVE_PER_HOUR=20

# URL Google Apps Script Web App untuk menyimpan jawaban UAT/SUS ke Google Sheet.
UAT_APPS_SCRIPT_URL=
